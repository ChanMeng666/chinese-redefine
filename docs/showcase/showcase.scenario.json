{
  "project": "chinese-redefine",
  "baseUrl": "https://chinese-redefine.chanmeng-dev.workers.dev",
  "outDir": "docs/showcase",
  "loginWall": true,

  "viewports": {
    "desktop": { "width": 1280, "height": 800, "deviceScaleFactor": 2 },
    "mobile":  { "width": 390,  "height": 844, "deviceScaleFactor": 3, "isMobile": true }
  },

  "reducedMotion": "reduce",

  "pages": [
    {
      "label": "gallery",
      "url": "/gallery",
      "viewport": "desktop",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2000 }
      ]
    },
    {
      "label": "gallery-scroll",
      "url": "/gallery",
      "viewport": "desktop",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2000 },
        { "action": "scroll", "by": 600 },
        { "action": "wait", "ms": 800 }
      ]
    },
    {
      "label": "login",
      "url": "/login",
      "viewport": "desktop",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2000 }
      ]
    },
    {
      "label": "mobile-gallery",
      "url": "/gallery",
      "viewport": "mobile",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2000 }
      ]
    }
  ],

  "demo": {
    "size": { "width": 1280, "height": 720 },
    "stepPauseMs": 700,
    "steps": [
      { "action": "goto", "url": "/gallery", "timeoutMs": 15000 },
      { "action": "wait", "ms": 2000 },
      { "action": "scroll", "by": 400 },
      { "action": "wait", "ms": 900 },
      { "action": "scroll", "by": 400 },
      { "action": "wait", "ms": 900 },
      { "action": "scroll", "by": 400 },
      { "action": "wait", "ms": 900 },
      { "action": "scroll", "by": -1200 },
      { "action": "wait", "ms": 800 }
    ]
  }
}
